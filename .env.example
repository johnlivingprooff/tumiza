# ── App ──────────────────────────────────────────────────────────────────────
# Generate a strong secret (min 32 chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=your-strong-random-secret-here-at-least-32-chars

# ── Database ──────────────────────────────────────────────────────────────────
# PlanetScale / any MySQL-compatible URL
DATABASE_URL=mysql://user:password@host:3306/tumiza

# ── Seed passwords (used by: npx tsx db/seed-users.ts) ───────────────────────
# If not set, a secure random password is generated and printed to stdout.
SEED_ADMIN_PASSWORD=
SEED_OFFICER_PASSWORD=

# ── Africa's Talking (SMS + WhatsApp) ─────────────────────────────────────────
# Use username "sandbox" and any key for local testing
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=TUMIZA
AT_WHATSAPP_PRODUCT_ID=
AT_WHATSAPP_CHANNEL=
